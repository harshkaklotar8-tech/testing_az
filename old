<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Harsh Kaklotar — LinkedIn Personal Branding for US CPA Professionals. Done-for-you LinkedIn management that builds authority and attracts premium clients.">
<title>Harsh Kaklotar — LinkedIn Branding for US CPAs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<script src="data.js"></script>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --white:   #ffffff;
  --off:     #f7f7f5;
  --ink:     #0f0f0f;
  --ink2:    #3a3a3a;
  --ink3:    #767676;
  --line:    #e8e8e4;
  --accent:  #1a56db;
  --accent2: #0e3fa8;
  --tag-bg:  #eef3ff;
  --tag-txt: #1a56db;
  --r:       6px;
}

html { scroll-behavior: smooth; }

body {
  background: var(--white);
  color: var(--ink);
  font-family: 'Sora', sans-serif;
  font-weight: 300;
  font-size: 16px;
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 60px; height: 68px;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s;
}
nav.scrolled { border-color: var(--line); }

.nav-logo {
  font-size: 15px; font-weight: 600; color: var(--ink);
  text-decoration: none; letter-spacing: -0.01em;
}
.nav-logo span { color: var(--accent); }

.nav-links { display: flex; align-items: center; gap: 36px; }
.nav-links a {
  font-size: 13px; font-weight: 400; color: var(--ink2);
  text-decoration: none; letter-spacing: -0.01em;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--ink); }

.nav-btn {
  font-size: 13px; font-weight: 500;
  background: var(--ink); color: var(--white);
  padding: 10px 22px; border-radius: 100px;
  text-decoration: none; letter-spacing: -0.01em;
  transition: background 0.2s, transform 0.15s;
}
.nav-btn:hover { background: var(--accent); transform: translateY(-1px); }

.nav-mobile-btn { display: none; }

/* ── HERO ── */
.hero {
  padding: 160px 60px 100px;
  max-width: 1160px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 80px; align-items: center;
}

.hero-tag {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--tag-bg); color: var(--tag-txt);
  font-size: 12px; font-weight: 500;
  padding: 6px 14px; border-radius: 100px;
  letter-spacing: 0.02em; margin-bottom: 28px;
}
.hero-tag::before {
  content: ''; width: 6px; height: 6px;
  background: var(--accent); border-radius: 50%;
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; } 50% { opacity: 0.3; }
}

.hero-h1 {
  font-size: clamp(36px, 4.5vw, 58px);
  font-weight: 700; line-height: 1.1;
  letter-spacing: -0.03em; color: var(--ink);
  margin-bottom: 20px;
}
.hero-h1 em {
  font-style: normal; color: var(--accent);
}

.hero-p {
  font-size: 17px; color: var(--ink2);
  line-height: 1.7; margin-bottom: 36px;
  font-weight: 300; max-width: 480px;
}

.hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

.btn-fill {
  font-size: 14px; font-weight: 500;
  background: var(--ink); color: var(--white);
  padding: 14px 28px; border-radius: 100px;
  text-decoration: none; letter-spacing: -0.01em;
  transition: background 0.2s, transform 0.15s;
  white-space: nowrap;
}
.btn-fill:hover { background: var(--accent); transform: translateY(-1px); }

.btn-ghost {
  font-size: 14px; font-weight: 400;
  color: var(--ink2); padding: 14px 28px;
  border-radius: 100px; text-decoration: none;
  border: 1px solid var(--line); letter-spacing: -0.01em;
  transition: border-color 0.2s, color 0.2s;
  white-space: nowrap;
}
.btn-ghost:hover { border-color: var(--ink2); color: var(--ink); }

/* Hero right — proof card */
.hero-card {
  background: var(--off); border-radius: 20px;
  padding: 36px; border: 1px solid var(--line);
}

.hero-card-label {
  font-size: 11px; font-weight: 500; color: var(--ink3);
  letter-spacing: 0.06em; text-transform: uppercase;
  margin-bottom: 24px;
}

.hero-stat-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
  border: 1px solid var(--line); border-radius: var(--r);
  overflow: hidden; margin-bottom: 20px;
}
.hero-stat {
  background: var(--white); padding: 20px 18px;
  border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.hero-stat:nth-child(2) { border-right: none; }
.hero-stat:nth-child(3) { border-bottom: none; }
.hero-stat:nth-child(4) { border-right: none; border-bottom: none; }

.hero-stat-num {
  font-size: 26px; font-weight: 700;
  color: var(--ink); letter-spacing: -0.03em;
  display: block; line-height: 1;
}
.hero-stat-lbl {
  font-size: 11px; color: var(--ink3);
  margin-top: 4px; display: block;
}

.hero-firms {
  font-size: 12px; color: var(--ink3); line-height: 1.6;
}
.hero-firms strong { color: var(--ink2); font-weight: 500; }

/* ── SECTION WRAPPER ── */
.section { padding: 100px 60px; max-width: 1160px; margin: 0 auto; }
.section-full { padding: 100px 0; }
.section-full .section-inner { max-width: 1160px; margin: 0 auto; padding: 0 60px; }

hr.divider { border: none; border-top: 1px solid var(--line); max-width: 1160px; margin: 0 auto; }

/* Section header */
.sh { margin-bottom: 56px; }
.sh-tag {
  font-size: 12px; font-weight: 500; color: var(--accent);
  letter-spacing: 0.04em; text-transform: uppercase;
  margin-bottom: 12px; display: block;
}
.sh-h2 {
  font-size: clamp(28px, 3.5vw, 44px); font-weight: 700;
  letter-spacing: -0.03em; line-height: 1.15; color: var(--ink);
}
.sh-h2 em { font-style: normal; color: var(--ink3); }
.sh-p {
  font-size: 16px; color: var(--ink3); max-width: 500px;
  line-height: 1.7; margin-top: 14px; font-weight: 300;
}

/* ── LOGOS (Big 4 trust bar) ── */
.trust-bar {
  background: var(--off);
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  padding: 28px 60px;
}
.trust-inner {
  max-width: 1160px; margin: 0 auto;
  display: flex; align-items: center; gap: 48px; flex-wrap: wrap;
}
.trust-label {
  font-size: 11px; font-weight: 500; color: var(--ink3);
  letter-spacing: 0.06em; text-transform: uppercase;
  white-space: nowrap; flex-shrink: 0;
}
.trust-firms {
  display: flex; gap: 40px; flex-wrap: wrap; align-items: center;
}
.trust-firm {
  font-size: 14px; font-weight: 600; color: var(--ink3);
  letter-spacing: -0.01em;
}

/* ── PROBLEM ── */
.problem-list {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1px; border: 1px solid var(--line); border-radius: var(--r);
  overflow: hidden;
}
.prob {
  padding: 36px 28px; background: var(--white);
  border-right: 1px solid var(--line);
  transition: background 0.2s;
}
.prob:last-child { border-right: none; }
.prob:hover { background: var(--off); }
.prob-icon {
  width: 40px; height: 40px; border-radius: 10px;
  background: var(--tag-bg); display: flex; align-items: center;
  justify-content: center; margin-bottom: 20px; font-size: 18px;
}
.prob-title {
  font-size: 15px; font-weight: 600; color: var(--ink);
  margin-bottom: 8px; letter-spacing: -0.01em;
}
.prob-body { font-size: 13px; color: var(--ink3); line-height: 1.7; }

/* ── PROCESS ── */
.process-list { display: flex; flex-direction: column; gap: 1px; }
.step-row {
  display: grid; grid-template-columns: 56px 1fr;
  gap: 28px; padding: 32px 0; align-items: start;
  border-bottom: 1px solid var(--line);
}
.step-row:last-child { border-bottom: none; }
.step-n {
  font-size: 13px; font-weight: 600; color: var(--accent);
  padding-top: 3px; font-variant-numeric: tabular-nums;
}
.step-content {}
.step-title {
  font-size: 16px; font-weight: 600; color: var(--ink);
  letter-spacing: -0.02em; margin-bottom: 6px;
}
.step-body { font-size: 14px; color: var(--ink3); line-height: 1.7; }

/* ── PACKAGES ── */
.pkg-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr));
  gap: 16px; margin-top: 56px;
}
.pkg-card {
  border: 1px solid var(--line); border-radius: 14px;
  padding: 32px 28px; background: var(--white);
  display: flex; flex-direction: column;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  position: relative;
}
.pkg-card:hover {
  border-color: #c0c8e8;
  box-shadow: 0 8px 32px rgba(26,86,219,0.07);
  transform: translateY(-3px);
}
.pkg-card.pop {
  border-color: var(--accent);
  background: #fafbff;
}
.pop-badge {
  position: absolute; top: -12px; left: 28px;
  background: var(--accent); color: var(--white);
  font-size: 11px; font-weight: 600;
  padding: 4px 12px; border-radius: 100px;
  letter-spacing: 0.02em;
}
.pkg-tier {
  font-size: 11px; font-weight: 500; color: var(--ink3);
  letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px;
}
.pkg-name {
  font-size: 22px; font-weight: 700;
  color: var(--ink); letter-spacing: -0.02em; margin-bottom: 4px;
}
.pkg-tagline {
  font-size: 13px; color: var(--ink3);
  margin-bottom: 24px; font-family: 'Lora', serif;
  font-style: italic;
}
.pkg-sep { border: none; border-top: 1px solid var(--line); margin-bottom: 20px; }
.pkg-feats { list-style: none; flex: 1; margin-bottom: 24px; }
.pkg-feats li {
  font-size: 13px; color: var(--ink2); padding: 7px 0;
  border-bottom: 1px solid var(--line);
  display: flex; gap: 10px; align-items: flex-start; line-height: 1.5;
}
.pkg-feats li:last-child { border-bottom: none; }
.pkg-feats li::before {
  content: '✓'; color: var(--accent); font-weight: 600;
  font-size: 12px; flex-shrink: 0; margin-top: 1px;
}
.pkg-cta-btn {
  display: block; text-align: center;
  font-size: 13px; font-weight: 500;
  padding: 13px; border-radius: 100px;
  text-decoration: none; letter-spacing: -0.01em;
  transition: all 0.2s;
  border: 1px solid var(--ink);
  color: var(--ink); background: var(--white);
}
.pkg-cta-btn:hover { background: var(--ink); color: var(--white); }
.pkg-card.pop .pkg-cta-btn {
  background: var(--accent); color: var(--white); border-color: var(--accent);
}
.pkg-card.pop .pkg-cta-btn:hover { background: var(--accent2); border-color: var(--accent2); }
.pkg-terms {
  font-size: 11px; color: var(--ink3); text-align: center;
  margin-top: 10px; letter-spacing: 0.02em;
}

/* ── ABOUT ── */
.about-wrap {
  display: grid; grid-template-columns: 1fr 1.4fr;
  gap: 80px; align-items: start;
}
.about-left {}
.about-avatar {
  width: 100%; aspect-ratio: 3/4; border-radius: 16px;
  background: var(--off); border: 1px solid var(--line);
  display: flex; align-items: center; justify-content: center;
  font-size: 72px; font-weight: 700; color: var(--ink3);
  letter-spacing: -0.04em;
}
.about-right {}
.about-name {
  font-size: clamp(28px, 3vw, 40px); font-weight: 700;
  letter-spacing: -0.03em; margin-bottom: 4px;
}
.about-role {
  font-size: 16px; color: var(--ink3); margin-bottom: 28px;
  font-family: 'Lora', serif; font-style: italic;
}
.about-body {
  font-size: 15px; color: var(--ink2); line-height: 1.8;
  margin-bottom: 32px; font-weight: 300;
}
.about-body strong { color: var(--ink); font-weight: 600; }

.creds { display: flex; flex-direction: column; gap: 10px; }
.cred {
  display: flex; align-items: center; gap: 12px;
  font-size: 13px; color: var(--ink2);
}
.cred-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0;
}

/* ── PROOF QUOTE ── */
.proof-wrap {
  background: var(--ink); border-radius: 20px;
  padding: 64px; text-align: center;
}
.proof-quote {
  font-family: 'Lora', serif;
  font-size: clamp(20px, 2.5vw, 30px);
  font-style: italic; color: var(--white);
  line-height: 1.5; margin-bottom: 20px; font-weight: 400;
}
.proof-quote em { font-style: normal; color: #93aff5; }
.proof-attr {
  font-size: 12px; color: rgba(255,255,255,0.4);
  letter-spacing: 0.05em; text-transform: uppercase;
  margin-bottom: 48px;
}
.proof-nums {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--r); overflow: hidden;
}
.proof-num-cell {
  padding: 24px; background: rgba(255,255,255,0.04);
  border-right: 1px solid rgba(255,255,255,0.08);
}
.proof-num-cell:last-child { border-right: none; }
.proof-big {
  font-size: 28px; font-weight: 700;
  color: var(--white); letter-spacing: -0.03em;
  display: block; line-height: 1;
}
.proof-lbl {
  font-size: 11px; color: rgba(255,255,255,0.4);
  display: block; margin-top: 4px;
}

/* ── FINAL CTA ── */
.fcta-wrap {
  background: var(--off); border-radius: 20px;
  padding: 80px 60px; text-align: center;
  border: 1px solid var(--line);
}
.fcta-wrap h2 {
  font-size: clamp(28px, 4vw, 52px); font-weight: 700;
  letter-spacing: -0.03em; margin-bottom: 16px; line-height: 1.1;
}
.fcta-wrap p {
  font-size: 16px; color: var(--ink2); max-width: 460px;
  margin: 0 auto 36px; line-height: 1.7; font-weight: 300;
}

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--line);
  padding: 32px 60px;
  display: flex; justify-content: space-between;
  align-items: center; flex-wrap: wrap; gap: 16px;
  max-width: 1280px; margin: 0 auto;
}
.footer-logo { font-size: 14px; font-weight: 600; color: var(--ink); text-decoration: none; }
.footer-logo span { color: var(--accent); }
.footer-links { display: flex; gap: 28px; }
.footer-links a {
  font-size: 13px; color: var(--ink3); text-decoration: none; transition: color 0.2s;
}
.footer-links a:hover { color: var(--ink); }
.footer-copy { font-size: 12px; color: var(--ink3); }

/* ── MODAL ── */
.modal-ov {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(15,15,15,0.5);
  backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center;
  padding: 20px;
  opacity: 0; visibility: hidden;
  transition: opacity 0.25s, visibility 0.25s;
}
.modal-ov.open { opacity: 1; visibility: visible; }

.modal-box {
  background: var(--white); border-radius: 20px;
  padding: 48px; max-width: 480px; width: 100%;
  position: relative;
  transform: translateY(16px) scale(0.98);
  transition: transform 0.25s;
  border: 1px solid var(--line);
  max-height: 90vh; overflow-y: auto;
}
.modal-ov.open .modal-box { transform: translateY(0) scale(1); }

.modal-close {
  position: absolute; top: 16px; right: 18px;
  background: var(--off); border: none; border-radius: 50%;
  width: 32px; height: 32px; font-size: 16px;
  cursor: pointer; color: var(--ink2);
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
.modal-close:hover { background: var(--line); }

.modal-tag {
  font-size: 11px; font-weight: 500; color: var(--accent);
  letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 8px;
}
.modal-box h3 {
  font-size: 24px; font-weight: 700; letter-spacing: -0.02em;
  margin-bottom: 6px;
}
.modal-box > p {
  font-size: 14px; color: var(--ink3); margin-bottom: 28px; line-height: 1.6;
}

.fg { margin-bottom: 14px; }
.fg label {
  font-size: 11px; font-weight: 600; color: var(--ink2);
  letter-spacing: 0.04em; text-transform: uppercase;
  display: block; margin-bottom: 6px;
}
.fg input, .fg select, .fg textarea {
  width: 100%; border: 1px solid var(--line); border-radius: var(--r);
  padding: 11px 14px; font-family: 'Sora', sans-serif;
  font-size: 14px; color: var(--ink); background: var(--white);
  outline: none; transition: border-color 0.2s;
  font-weight: 300;
}
.fg input:focus, .fg select:focus, .fg textarea:focus {
  border-color: var(--accent);
}
.fg select { cursor: pointer; }
.fg textarea { resize: vertical; min-height: 80px; }

.modal-submit {
  width: 100%; margin-top: 6px;
  background: var(--ink); color: var(--white);
  border: none; border-radius: 100px;
  font-family: 'Sora', sans-serif;
  font-size: 14px; font-weight: 500;
  padding: 15px; cursor: pointer;
  letter-spacing: -0.01em;
  transition: background 0.2s, transform 0.15s;
}
.modal-submit:hover { background: var(--accent); transform: translateY(-1px); }
.modal-note {
  font-size: 11px; color: var(--ink3);
  text-align: center; margin-top: 12px;
}

/* ── SCROLL REVEAL ── */
.r { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
.r.on { opacity: 1; transform: none; }
.r.d1 { transition-delay: 0.08s; }
.r.d2 { transition-delay: 0.16s; }
.r.d3 { transition-delay: 0.24s; }
.r.d4 { transition-delay: 0.32s; }

/* ── MOBILE ── */
@media (max-width: 900px) {

  /* Nav */
  nav { padding: 0 20px; height: 60px; }
  .nav-links { display: none; }
  .nav-btn { display: none; }
  .nav-mobile-btn {
    display: block;
    font-size: 13px; font-weight: 500;
    background: var(--ink); color: var(--white);
    padding: 9px 18px; border-radius: 100px;
    text-decoration: none; letter-spacing: -0.01em;
  }

  /* Hero */
  .hero {
    grid-template-columns: 1fr;
    padding: 90px 20px 52px;
    gap: 36px;
  }
  .hero-h1 { font-size: 36px; }
  .hero-p { font-size: 15px; }
  .hero-actions { flex-direction: column; gap: 10px; }
  .btn-fill, .btn-ghost { text-align: center; width: 100%; }
  .hero-card { padding: 24px 20px; }
  .hero-stat-grid { grid-template-columns: 1fr 1fr; }
  .hero-stat { padding: 16px 14px; }
  .hero-stat-num { font-size: 20px; }

  /* Trust bar */
  .trust-bar { padding: 20px; }
  .trust-inner { flex-direction: column; gap: 12px; }
  .trust-firms { gap: 20px; }
  .trust-firm { font-size: 13px; }

  /* Sections */
  .section { padding: 52px 20px; }
  .section-full .section-inner { padding: 0 20px; }

  /* Problem */
  .problem-list { grid-template-columns: 1fr; border-radius: var(--r); }
  .prob { border-right: none; border-bottom: 1px solid var(--line); padding: 28px 20px; }
  .prob:last-child { border-bottom: none; }

  /* How it works — fix the two-column grid */
  #how > div { grid-template-columns: 1fr !important; gap: 36px !important; }
  .sh { margin-bottom: 0; }
  .step-row { padding: 24px 0; grid-template-columns: 40px 1fr; gap: 16px; }
  .step-n { font-size: 12px; padding-top: 2px; }
  .step-title { font-size: 15px; }
  .step-body { font-size: 13px; }

  /* Packages */
  .pkg-grid { grid-template-columns: 1fr; gap: 12px; margin-top: 36px; }
  .pkg-card { padding: 28px 20px; }
  .pop-badge { left: 20px; }

  /* About */
  .about-wrap { grid-template-columns: 1fr; gap: 28px; }
  .about-avatar { aspect-ratio: 16/9; font-size: 40px; border-radius: 12px; }
  .about-name { font-size: 28px; }
  .about-body { font-size: 14px; }

  /* Proof */
  .proof-wrap { padding: 36px 20px; border-radius: 14px; }
  .proof-quote { font-size: 18px; }
  .proof-nums { grid-template-columns: 1fr; }
  .proof-num-cell {
    border-right: none;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 20px;
  }
  .proof-num-cell:last-child { border-bottom: none; }
  .proof-big { font-size: 24px; }

  /* CTA */
  .fcta-wrap { padding: 44px 20px; border-radius: 14px; }
  .fcta-wrap h2 { font-size: 28px; }
  .fcta-wrap p { font-size: 14px; }
  .btn-fill { padding: 14px 24px; font-size: 14px; }

  /* Modal */
  .modal-box { padding: 28px 20px; border-radius: 16px; }
